# Required for v0 (web/Electron)
E2B_API_KEY=
REPLICATE_API_TOKEN=

# Optional
ANTHROPIC_API_KEY=

# Detector backend: replicate | http | local
INSPECTOR_DETECTOR=replicate
# If INSPECTOR_DETECTOR=http, point at a self-hosted OmniParser FastAPI server:
INSPECTOR_OMNIPARSER_URL=

# Optional: custom E2B desktop template with google-chrome pre-installed. The stock
# template ships Firefox only (no CDP), so the web adapter installs chrome at launch
# (~30-60s/session) unless this points at a template that already has it.
E2B_TEMPLATE=

# macOS plane (iOS adapter) — set to the IP of a running tart VM or remote Mac
INSPECTOR_MACOS_HOST=
INSPECTOR_MACOS_USER=admin
INSPECTOR_MACOS_PASSWORD=admin

# --- Devin auto-fix (the "Fix with Devin" button on the Bug Ledger) ---
# Get a key at https://app.devin.ai -> Settings -> API Keys (org admin; key starts apk_).
DEVIN_API_KEY=
# Optional: cap cost per fix (Devin ACUs) and the dashboard poll wait (seconds).
INSPECTOR_DEVIN_MAX_ACU=
INSPECTOR_DEVIN_TIMEOUT=600

# --- MCP transport ---
# stdio (default, for Claude Code/Cursor) or http/sse so a REMOTE client (e.g. Devin,
# via its MCP marketplace) can call Inspector. For http, expose host:port/path with a
# tunnel (ngrok/cloudflared) since Devin runs in the cloud.
INSPECTOR_TRANSPORT=stdio
INSPECTOR_HTTP_HOST=127.0.0.1
INSPECTOR_HTTP_PORT=8765
INSPECTOR_HTTP_PATH=/mcp
