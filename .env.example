# ── Required ────────────────────────────────────────────────────────────────
# Element detector (OmniParser on Replicate) — draws the numbered Set-of-Mark
# boxes the host agent grounds on. This is the one key you need to get started.
REPLICATE_API_TOKEN=

# Detector backend: replicate (default, uses the token above) | http
INSPECTOR_DETECTOR=replicate
# If INSPECTOR_DETECTOR=http, point at a self-hosted OmniParser FastAPI server:
INSPECTOR_OMNIPARSER_URL=

# ── Optional ────────────────────────────────────────────────────────────────
# E2B sandbox plane — ONLY needed to run web/Electron apps in an ISOLATED VM.
# Leave blank to run them locally (execution=local). NOT required to start.
E2B_API_KEY=
# Optional custom E2B template with google-chrome pre-installed (the stock template
# ships Firefox only, so the web adapter installs chrome at launch ~30-60s otherwise).
E2B_TEMPLATE=

# Anthropic — ONLY for the autonomous test_app autopilot brain. The host coding
# agent (Claude Code) is the brain by default, so this is optional.
ANTHROPIC_API_KEY=

# macOS plane (iOS adapter) — set to the IP of a running tart VM or remote Mac.
INSPECTOR_MACOS_HOST=
INSPECTOR_MACOS_USER=admin

# --- Devin auto-fix (optional; the "Fix with Devin" button on the Bug Ledger) ---
# Key at https://app.devin.ai -> Settings -> API Keys (org admin; starts apk_).
DEVIN_API_KEY=
INSPECTOR_DEVIN_MAX_ACU=
INSPECTOR_DEVIN_TIMEOUT=600
# Optional: pin the GitHub repo Devin opens PRs against (owner/name). Defaults to
# the app-under-test's own git remote.
INSPECTOR_DEVIN_REPO=

# --- MCP transport ---
# stdio (default, for Claude Code/Cursor) or http/sse for a REMOTE client. HTTP binds
# 127.0.0.1 only (no auth yet); expose it via an authenticated tunnel for remote use.
INSPECTOR_TRANSPORT=stdio
INSPECTOR_HTTP_HOST=127.0.0.1
INSPECTOR_HTTP_PORT=8765
INSPECTOR_HTTP_PATH=/mcp
